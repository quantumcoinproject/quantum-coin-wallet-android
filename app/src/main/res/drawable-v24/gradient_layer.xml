<!-- The width/height intentionally declare a 1dp intrinsic size rather than
     the viewport's 385x224. When this drawable is used as a View background
     (e.g. top_linear_layout_home_id in home_activity.xml), the View's
     minimum height is bounded below by the background's intrinsic height
     (View.getSuggestedMinimumHeight() == max(minHeight, background.getMinimumHeight())).
     With a 224dp intrinsic height, the banner was forced to ~224dp on every
     device even though its content (50dp logo + title text) is only ~80dp,
     producing visible empty gradient space below the logo. Backgrounds are
     stretched to the View's bounds regardless of intrinsic size, and the
     viewportWidth/viewportHeight below (which drive the gradient math) are
     unchanged, so the rendered gradient is visually identical. -->
<vector
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="1dp"
    android:height="1dp"
    android:viewportWidth="385"
    android:viewportHeight="224"
    >
    <group>
        <clip-path
            android:pathData="M0 0H385V224H0V0Z"
            />
        <group
            android:translateX="0"
            android:translateY="-0.901"
            android:pivotX="192.5"
            android:pivotY="112"
            android:scaleX="2"
            android:scaleY="5.605"
            >
            <path
                android:pathData="M0 0V224H385V0"
                >
                <aapt:attr name="android:fillColor">
                    <gradient
                        android:type="linear"
                        android:startX="96.25"
                        android:startY="112"
                        android:endX="288.75"
                        android:endY="112"
                        >
                        <item
                            android:color="#80421096"
                            android:offset="0"
                            />
                        <item
                            android:color="#4059D6F2"
                            android:offset="0.245"
                            />
                        <item
                            android:color="#26EC6B7C"
                            android:offset="0.495"
                            />
                        <item
                            android:color="#0DB5498C"
                            android:offset="0.755"
                            />
                        <item
                            android:color="#0D903690"
                            android:offset="1"
                            />
                        <item
                            android:color="#0D903690"
                            android:offset="1"
                            />
                    </gradient>
                </aapt:attr>
            </path>
        </group>
    </group>
</vector>

