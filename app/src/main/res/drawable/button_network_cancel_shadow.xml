<?xml version="1.0" encoding="utf-8"?>
<!--
    Cancel-button drawable scoped to the network-selection dialog.
    The shared button_gray_shadow uses @color/colorCommon3, which
    flips from #807d7d (gray) in light mode to #FFFFFF (white) in
    dark mode. Inside this dialog the user wants the cancel button
    to stay GRAY in both modes — light text on gray in light mode
    and dark text on gray in dark mode — so we hard-code the gray
    fill here and pair it with @color/colorCommon7 text in the
    layout (white in light, black in dark).
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <layer-list>
            <item android:bottom="2dp" android:left="2dp">
                <shape>
                    <gradient android:angle="90"
                        android:startColor="#807d7d"
                        android:centerColor="#807d7d"
                        android:endColor="#807d7d" />
                    <stroke android:width="1dp" android:color="#807d7d" />
                    <corners android:radius="16dp" />
                    <padding android:bottom="10dp" android:left="10dp"
                        android:right="10dp" android:top="10dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
