<?xml version="1.0" encoding="utf-8"?>
<!--
  Backup options screen. Mirrors iOS BackupOptionsViewController:
  back arrow + title + body + hairline divider + Cloud + File buttons.
  Deliberately NO Done/Next button — iOS omits it on this surface and
  we match. The flow is: tap Cloud or File, the existing
  BackupPasswordDialog asks for a NEW backup password, and the SAF
  picker takes over from there.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/scroll_backup_options"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/linear_layout_backup_options"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="14dp"
        android:paddingBottom="20dp">

        <!-- Back row: 55dp tall, 55dp icon, 5dp padding, transparent
             click bg. Sized AND positioned to match every other
             Android screen's back arrow (account_transactions, send,
             receive, reveal, settings, wallet, blockchain_network,
             etc. all use the same 55dp / 5dp pair sitting flush at
             the screen edge — the visible icon's left edge then
             lands at 5dp). The body content below applies its own
             20dp horizontal margin so the title / buttons keep their
             readable indent without dragging the back arrow inward.
             The earlier outer paddingLeft="20dp" pushed THIS row
             inward by an extra 20dp, making the icon land at 25dp
             from the screen edge — visibly further right than every
             sibling screen. -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginBottom="14dp">

            <ImageView
                android:id="@+id/imageView_backup_options_back"
                android:layout_width="55dp"
                android:layout_height="55dp"
                android:layout_gravity="start|center_vertical"
                android:src="@drawable/arrow_back_circle_outline"
                android:background="@drawable/image_selector"
                android:padding="5dp"
                android:scaleType="fitCenter"
                android:contentDescription="@string/password_toggle_content_description" />

        </FrameLayout>

        <!-- Title — 18sp bold, multiline. -->
        <TextView
            android:id="@+id/textView_backup_options_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/colorCommon6"
            android:layout_marginBottom="14dp" />

        <!-- Body — 13sp, multiline. -->
        <TextView
            android:id="@+id/textView_backup_options_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:textSize="13sp"
            android:textColor="@color/colorCommon6"
            android:layout_marginBottom="14dp" />

        <!-- Hairline divider — 1dp, semi-transparent, mirrors iOS makeRule(). -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:alpha="0.2"
            android:background="@drawable/line_2_shape"
            android:layout_marginBottom="14dp" />

        <!-- Cloud backup button — full-width, 44dp tall pill. -->
        <Button
            android:id="@+id/button_backup_options_cloud"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:textAllCaps="false"
            android:textColor="@color/colorCommon7"
            android:background="@drawable/button_green_selector"
            android:layout_marginBottom="14dp"
            android:visibility="gone" />

        <!-- File backup button — same shape. -->
        <Button
            android:id="@+id/button_backup_options_file"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:textAllCaps="false"
            android:textColor="@color/colorCommon7"
            android:background="@drawable/button_green_selector" />

    </LinearLayout>

</ScrollView>
