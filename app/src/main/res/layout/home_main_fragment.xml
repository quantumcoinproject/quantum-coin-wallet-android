<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_gravity="center_horizontal|center_vertical"
    android:background="@android:color/transparent"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/tokenList_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="12dp">

        <TextView
            android:id="@+id/textView_tokenList_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14dp"
            android:textStyle="bold"
            android:textColor="@color/colorCommon1"
            android:paddingBottom="8dp"
            tools:ignore="HardcodedText" />

        <LinearLayout
            android:id="@+id/tokenList_header_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:baselineAligned="false">

            <TextView
                android:id="@+id/textView_tokenList_header_symbol"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="12dp"
                android:textStyle="bold"
                android:textColor="@color/colorCommon10" />

            <TextView
                android:id="@+id/textView_tokenList_header_balance"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.4"
                android:textSize="12dp"
                android:textStyle="bold"
                android:textColor="@color/colorCommon10" />

            <TextView
                android:id="@+id/textView_tokenList_header_contract"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.4"
                android:textSize="12dp"
                android:textStyle="bold"
                android:textColor="@color/colorCommon10" />

            <TextView
                android:id="@+id/textView_tokenList_header_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:textSize="12dp"
                android:textStyle="bold"
                android:textColor="@color/colorCommon10" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:alpha="0.25"
            android:background="@drawable/separator_line_vertical" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView_tokenList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="vertical" />

        <TextView
            android:id="@+id/textView_tokenList_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingTop="20dp"
            android:paddingBottom="20dp"
            android:textSize="13dp"
            android:textColor="@color/colorCommon10"
            android:visibility="gone" />

    </LinearLayout>

</RelativeLayout>
