<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_gravity="center_horizontal|center_vertical"
    android:background="@android:color/transparent">

    <LinearLayout
        android:id="@+id/linerLayout_send_offline"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:gravity="center_vertical|center_horizontal"
        android:visibility="gone">

        <include layout="@layout/retry_layout"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/linerLayout_send_offline">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/top_linear_layout_send_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:background="@android:color/transparent">

                <ImageButton
                    android:id="@+id/imageButton_send_back_arrow"
                    android:layout_width="55dp"
                    android:layout_height="55dp"
                    android:padding="5dp"
                    android:scaleType="fitCenter"
                    android:layout_gravity="left"
                    android:background="@drawable/image_selector"
                    android:src="@drawable/arrow_back_circle_outline"
                    app:tint="@color/colorCommon6"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/top_linear_layout_send_id"
                android:layout_centerHorizontal="true"
                android:layout_marginLeft="10dp"
                android:layout_marginRight="10dp"
                android:background="@drawable/center_container">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="15dp"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="10dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal|center_vertical"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/textView_send_langValue_send"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="20dp"
                            android:textStyle="bold"
                            android:textColor="@color/colorCommon6"/>

                        <View
                            android:layout_width="wrap_content"
                            android:layout_height="1dp"
                            android:layout_marginTop="20dp"
                            android:layout_marginBottom="10dp"
                            android:alpha="0.2"
                            android:background="@drawable/line_2_shape" />

                        <TextView
                            android:id="@+id/textView_send_langValue_network"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:textStyle="bold"
                            android:textSize="16dp" />

                        <TextView
                            android:id="@+id/textView_send_network_value"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingBottom="10dp"
                            android:textSize="14dp"
                            android:textColor="@color/colorCommon6" />

                        <!--
                            "Show Unrecognized Tokens" toggle.
                            Visibility is owned by SendFragment; the row
                            is hidden when there are no unrecognized
                            tokens to reveal. The toggle defaults OFF so
                            that on a cold launch the spinner only
                            offers the recognized allow-list (HSN, Y2Q
                            today) plus the native QC coin. Mirrors iOS
                            SendViewController's
                            "Show Unrecognized Tokens" UISwitch.
                        -->
                        <LinearLayout
                            android:id="@+id/row_send_show_unrecognized"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:visibility="gone">

                            <TextView
                                android:id="@+id/textView_send_show_unrecognized"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:textSize="13dp"
                                android:textColor="@color/colorCommon6" />

                            <Switch
                                android:id="@+id/switch_send_show_unrecognized"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/textView_send_asset_label"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textStyle="bold"
                            android:textSize="16dp" />

                        <Spinner
                            android:id="@+id/spinner_send_asset"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="4dp"
                            android:minHeight="44dp"
                            android:paddingStart="10dp"
                            android:paddingEnd="32dp"
                            android:background="@drawable/spinner_dropdown_background" />

                        <!--
                            Selected-token caption that renders the
                            chosen token's contract address (or
                            "QuantumCoin" for the native coin) right
                            below the asset spinner. Populated by
                            SendFragment.setupAssetSpinner() inside
                            the spinner's OnItemSelectedListener.

                            Uses colorMutedSecondaryText (a dedicated
                            theme-aware muted gray) instead of
                            colorCommon10. colorCommon10 looks correct
                            in light mode but resolves to #000000 in
                            dark mode because that resource is also
                            consumed as a *dialog background* in dark
                            mode and so cannot be retuned. Routing
                            through colorMutedSecondaryText keeps the
                            light-mode appearance byte-for-byte
                            identical and gives dark mode a soft
                            #B0B0B0 that's legible against the dark
                            screen background.
                        -->
                        <TextView
                            android:id="@+id/textView_send_asset_selected"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:textSize="12dp"
                            android:textColor="@color/colorMutedSecondaryText" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:gravity="left|center_vertical"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/textView_send_langValue_balance"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="16dp"
                                android:textStyle="bold"/>
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="left|center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/textView_send_coin_symbol"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textStyle="bold"
                                    android:textSize="24dp"
                                    android:textColor="@color/colorCommon6"
                                    android:visibility="gone"/>

                                <TextView
                                    android:id="@+id/textView_send_balance_value"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textSize="18dp"
                                    android:textStyle="bold"
                                    android:textColor="@color/colorCommon6" />

                                <ProgressBar
                                    android:id="@+id/progress_send_loader"
                                    android:layout_width="25dp"
                                    android:layout_height="26dp"
                                    android:padding="5dp"
                                    android:indeterminate="true"
                                    android:visibility="gone"
                                    android:max="100"
                                    android:progress="0"
                                    android:background="@android:color/transparent"
                                    android:indeterminateDrawable="@drawable/progress" />
                            </LinearLayout>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/textView_send_address_to_send"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:textStyle="bold"
                                android:textSize="16dp" />

                            <!--
                                 Block-explorer shortcut. Hidden by default;
                                 SendFragment toggles to VISIBLE only when the
                                 typed/pasted/scanned address passes the
                                 SDK's `isValidAddressAsync`. Mirrors iOS
                                 SendViewController.addressExplorerButton.
                            -->
                            <ImageButton
                                android:id="@+id/imageButton_send_address_explorer"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:padding="5dp"
                                android:layout_gravity="center_vertical"
                                android:layout_marginEnd="4dp"
                                android:background="@drawable/image_selector"
                                android:src="@drawable/address_explore"
                                app:tint="@color/colorCommon6"
                                android:visibility="gone"/>

                            <ImageButton
                                android:id="@+id/imageButton_scan_qr_code"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:padding="5dp"
                                android:layout_gravity="center_vertical"
                                android:background="@drawable/image_selector"
                                android:src="@android:drawable/ic_menu_camera"
                                android:visibility="visible"/>

                        </LinearLayout>

                        <EditText
                            android:id="@+id/editText_send_address_to_send"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:padding="5dp"
                            android:paddingBottom="10dp"
                            android:inputType="textNoSuggestions|textMultiLine"
                            android:textSize="14dp"
                            android:minLines="2"
                            android:gravity="top|start"
                            android:background="@drawable/text_input_selector" />

                        <TextView
                            android:id="@+id/textView_send_quantity_to_send"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textStyle="bold"
                            android:textSize="16dp" />

                        <EditText
                            android:id="@+id/editText_send_quantity_to_send"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical|left"
                            android:layout_weight="1"
                            android:layout_marginBottom="10dp"
                            android:padding="5dp"
                            android:maxLines="1"
                            android:ems="10"
                            android:textSize="14dp"
                            android:inputType="numberDecimal"
                            android:background="@drawable/text_input_selector"  />

                        <Button
                            android:id="@+id/button_send_send"
                            android:background="@drawable/button_green_selector"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical|right"
                            android:padding="5dp"
                            android:textAllCaps="false"
                            android:textColor="@color/colorCommon7" />

                 </LinearLayout>

                </RelativeLayout>

            </LinearLayout>

            <ProgressBar
                android:id="@+id/progress_loader_send_coins"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:layout_gravity="center_horizontal|center_vertical"
                android:layout_alignParentBottom="true"
                android:indeterminate="true"
                android:visibility="gone"
                android:max="100"
                android:progress="0"
                android:background="@android:color/transparent"
                android:indeterminateDrawable="@drawable/progress" />

        </RelativeLayout>

      </ScrollView>

    </LinearLayout>

</RelativeLayout>

