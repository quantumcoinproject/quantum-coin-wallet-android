<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!--
        Fixed 40dp row height + gravity-centered cells so the vertical
        column-divider Views (layout_height=match_parent) span the
        FULL row. Previously the row used wrap_content + paddingTop=10dp
        / paddingBottom=10dp, which under LinearLayout means the
        match_parent children get parent_height MINUS the padding, so
        each row's column dividers were ~20dp shorter than the row
        itself. Stacking rows produced a visible vertical break in the
        column line between rows (and between the header strip and the
        first row). The new layout mirrors wallet_adapter.xml /
        account_transactions_adapter.xml so the column dividers chain
        edge-to-edge across header + every row, broken only by the
        intentional 1dp horizontal row separator at the bottom of each
        row.
    -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:baselineAligned="false">

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:alpha="0.15"
            android:background="@drawable/separator_line_vertical" />

        <TextView
            android:id="@+id/textView_token_adapter_symbol"
            android:layout_width="90dp"
            android:layout_height="wrap_content"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:textSize="12dp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="1" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:alpha="0.15"
            android:background="@drawable/separator_line_vertical" />

        <TextView
            android:id="@+id/textView_token_adapter_balance"
            android:layout_width="130dp"
            android:layout_height="wrap_content"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:textSize="12dp"
            android:ellipsize="end"
            android:maxLines="1" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:alpha="0.15"
            android:background="@drawable/separator_line_vertical" />

        <TextView
            android:id="@+id/textView_token_adapter_contract"
            android:layout_width="140dp"
            android:layout_height="wrap_content"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:textSize="12dp"
            android:textColor="@color/colorCommon8"
            android:background="@drawable/text_link_selector_bg"
            android:ellipsize="middle"
            android:maxLines="1" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:alpha="0.15"
            android:background="@drawable/separator_line_vertical" />

        <TextView
            android:id="@+id/textView_token_adapter_name"
            android:layout_width="130dp"
            android:layout_height="wrap_content"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:textSize="12dp"
            android:ellipsize="end"
            android:maxLines="1" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:alpha="0.15"
            android:background="@drawable/separator_line_vertical" />

    </LinearLayout>

    <!--
        Bottom row divider. Mirrors the divider drawable + alpha used by
        account_transactions_adapter.xml so the two tables share the
        same row separator weight; column-internal separators stay on
        @drawable/separator_line_vertical at the canonical 0.15 alpha
        (also matching the transactions adapter).
    -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:alpha="0.2"
        android:background="@drawable/line_2_shape" />

</LinearLayout>
