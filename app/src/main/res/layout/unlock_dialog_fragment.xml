<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_centerHorizontal="true"
    android:background="@android:color/transparent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"
            android:background="@drawable/center_container">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="10dp">

                <LinearLayout
                android:id="@+id/linear_layout_unlock_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal|center_vertical"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textView_unlock_langValues_unlock_wallet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="20dp"
                    android:textStyle="bold"
                    android:textColor="@color/colorCommon6"/>

                <View
                    android:layout_width="wrap_content"
                    android:layout_height="1dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="10dp"
                    android:alpha="0.2"
                    android:background="@drawable/line_2_shape" />

                <TextView
                    android:id="@+id/textView_unlock_langValues_enter_wallet_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:textSize="16dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxBackgroundMode="outline"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:hintAnimationEnabled="true"
                    app:endIconMode="password_toggle"
                    app:endIconTint="@color/colorCommon6"
                    app:endIconDrawable="@drawable/show_password_selector"
                    app:endIconContentDescription="@string/password_toggle_content_description">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editText_unlock_langValues_enter_a_password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical|left"
                        android:layout_weight="1"
                        android:inputType="textPassword"
                        android:maxLines="1"
                        android:maxLength="100"
                        android:autofillHints="password"
                        android:importantForAutofill="yes"
                        android:background="@drawable/text_input_selector"  />

                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="1dp"
                    android:gravity="center_horizontal|center_vertical"
                    android:orientation="horizontal">
                    <!--
                        Close button uses the same button_green_selector
                        as the Unlock button (and Next across the app)
                        so the unlock dialog's primary-action chrome is
                        uniform with the rest of the product. textColor
                        stays at colorCommon7 (#FFFFFF in light,
                        #000000 in dark) so the label remains legible
                        against the green pill in both themes, matching
                        the Next / Unlock / OK pattern.
                    -->
                    <Button
                        android:id="@+id/button_unlock_langValues_close"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="4dp"
                        android:paddingLeft="20dp"
                        android:paddingRight="20dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:textAllCaps="false"
                        android:textColor="@color/colorCommon7"
                        android:background="@drawable/button_green_selector"/>

                    <Button
                        android:id="@+id/button_unlock_langValues_unlock"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="4dp"
                        android:paddingLeft="20dp"
                        android:paddingRight="20dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:textAllCaps="false"
                        android:textColor="@color/colorCommon7"
                        android:background="@drawable/button_green_selector"/>

                </LinearLayout>

            </LinearLayout>

            </RelativeLayout>

        </LinearLayout>

    </ScrollView>
</RelativeLayout>