<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31) data extraction rules (MF-09).

  See backup_rules.xml for the rationale. This file governs cloud-backup
  and device-to-device transfer on API 31+.

  We whitelist exactly one file: the wallet SharedPreferences blob, which
  is scrypt+AES encrypted at rest and gated at runtime by
  WalletBackupAgent before anything is emitted.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="sharedpref" path="DP_QUANTUM_COIN_WALLET_APP_PREF.xml" />
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="DP_QUANTUM_COIN_WALLET_APP_PREF.xml" />
    </device-transfer>
</data-extraction-rules>
